# Google Sheets（collector の書き込み先。SA鍵をJSON1行で）
SHEET_ID=
GOOGLE_SA_JSON=

# Supabase（設定すればシート直読みからSupabaseに自動切替）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth（Cloud Console → 認証情報 → OAuthクライアント）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# openssl rand -base64 32 で生成
AUTH_SECRET=
# 本番URL（Vercelデプロイ後に設定）
AUTH_URL=https://YOUR_VERCEL_URL

# Cron保護トークン（openssl rand -base64 32）
CRON_SECRET=

# Slack（失敗通知・週次レポート）
SLACK_BOT_TOKEN=
SLACK_REPORT_CHANNEL=
